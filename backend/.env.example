PORT=8080
CORS_ORIGIN=http://localhost:5173

# Data source: "demo" serves only curated seed crises and pauses live
# ingestion. Leave blank (or anything else) for live cross-agency feeds.
DATA_SOURCE=

# Supabase — from your project Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_SECRET_KEY=your_supabase_secret_key

# Auth
JWT_SECRET=change_this_to_a_long_random_string

# LLM — OpenAI chat-completions endpoint. gpt-4.1-mini handles both text and
# vision. LLM_TIMEOUT_SECONDS (default 60) can raise the per-attempt timeout.
LLM_API_KEY=your_openai_api_key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini

# Structured-output path (triage + task-card generation only). Runs ChatJSON on
# a stronger reasoning model while chat/vision stay on LLM_MODEL. Leave
# LLM_JSON_MODEL blank to reuse LLM_MODEL (no change). GPT-5/o-series models use
# max_completion_tokens automatically; LLM_JSON_REASONING_EFFORT is one of
# none|minimal|low|medium|high (defaults to low for reasoning models).
LLM_JSON_MODEL=gpt-5.4-mini
LLM_JSON_REASONING_EFFORT=low

# Voice transcription (OpenAI-compatible Whisper endpoint)
STT_API_KEY=your_stt_api_key
STT_BASE_URL=https://api.openai.com/v1
STT_MODEL=whisper-1
# STT_TIMEOUT_SECONDS=60

# LTA DataMall — free registration at datamall.lta.gov.sg
# Leave blank to skip LTA train alert ingestion
LTA_API_KEY=your_lta_api_key

# OneMap — free account at onemap.gov.sg. Enables precise neighbourhood

# Preferred: email + password — the server auto-fetches and auto-renews the
# token, so it never goes stale.
ONEMAP_EMAIL=your_onemap_account_email
ONEMAP_PASSWORD=your_onemap_account_password

