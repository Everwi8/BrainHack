PORT=8080
CORS_ORIGIN=http://localhost:5173

# Supabase — from your project Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_SECRET_KEY=your_supabase_secret_key

# Auth
JWT_SECRET=change_this_to_a_long_random_string

LLM_API_KEY=your_openrouter_api_key
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Voice transcription (OpenAI-compatible Whisper endpoint)
STT_API_KEY=your_stt_api_key
STT_BASE_URL=https://api.openai.com/v1
STT_MODEL=whisper-1
# STT_TIMEOUT_SECONDS=60

# LTA DataMall — free registration at datamall.lta.gov.sg
# Leave blank to skip LTA train alert ingestion
LTA_API_KEY=your_lta_api_key
